# КлассМаркет — Environment Variables
# Copy to .env and fill in values

# === Application ===
NODE_ENV=development
PORT=4000

# === Database ===
DB_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://klassmarket:${DB_PASSWORD}@localhost:5432/klassmarket

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Elasticsearch ===
ELASTICSEARCH_URL=http://localhost:9200

# === JWT Auth (RS256) ===
# Generate: ssh-keygen -t rsa -b 2048 -m PEM -f jwt.key && openssl rsa -in jwt.key -pubout > jwt.key.pub
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# === OAuth: VK ID ===
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=http://localhost:3000/auth/vk/callback

# === OAuth: Яндекс ID ===
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3000/auth/yandex/callback

# === Payments: ЮKassa ===
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_URL=http://localhost:4000/api/payments/webhook

# === Video: Jitsi Meet ===
JITSI_URL=https://localhost:8443
JITSI_APP_ID=klassmarket
JITSI_APP_SECRET=changeme

# === File Storage: MinIO ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=klassmarket

# === Email (SMTP) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@klassmarket.ru

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_JITSI_URL=https://localhost:8443
NEXT_PUBLIC_APP_URL=http://localhost:3000
